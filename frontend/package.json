{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "compodoc": "npx compodoc -p tsconfig.doc.json -d documentation -s -w",
    "deploy": "npm run build && npm run nginx:limpiar && npm run nginx:llenar",
    "nginx:limpiar": "del /F /Q C:\\nginx-1.30.2\\html\\* && for /d %x in (C:\\nginx-1.30.2\\html\\*) do rmdir /S /Q \"%x\"",
    "nginx:llenar": "xcopy /E /I dist\\frontend\\browser\\* C:\\nginx-1.30.2\\html\\",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@lucide/angular": "^1.17.0",
    "@ng-select/ng-select": "^21.8.2",
    "@primeuix/themes": "^2.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
